# Copy this file to .env and fill in your paths before running any notebook.

# Root directory of the BDD100K dataset on the Colab runtime
BDD100K_ROOT=/content/bdd100k

# Subdirectory containing detection labels (JSON format)
BDD100K_LABELS_DIR=/content/bdd100k/labels/det_20

# Subdirectory containing images
BDD100K_IMAGES_DIR=/content/bdd100k/images/100k

# Where converted YOLO-format data will be written
YOLO_DATA_DIR=/content/bdd100k_yolo

# Where converted COCO-format data will be written (for DETR models)
COCO_DATA_DIR=/content/bdd100k_coco

# Project root inside the Colab runtime (set to your Drive mount path if using Drive)
PROJECT_ROOT=/content/object-detection-under-visual-degradation

# Weights & Biases (optional — leave blank to disable)
WANDB_API_KEY=
WANDB_PROJECT=thesis-object-detection
